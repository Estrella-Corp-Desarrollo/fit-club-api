HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Public URL of this API (used in production config). Example:
# APP_URL=https://fit-club-api-tsihm.ondigitalocean.app

# --- Strava OAuth + webhook (optional; leave empty to keep oauthReady=false) ---
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match the Authorization Callback Domain / exact redirect registered in Strava.
# Recommended: API callback (then redirects to FitClubWeb).
# Example: https://fit-club-api-tsihm.ondigitalocean.app/api/app/strava/callback
STRAVA_REDIRECT_URI=
# Optional override for HMAC-signing OAuth state (defaults to JWT_SECRET)
# STRAVA_STATE_SECRET=
# Where to send the browser after OAuth (FitClubWeb)
# Example: https://your-fitclub-web.example
FITCLUB_WEB_URL=http://localhost:5173
# Webhook subscription (create via scripts/strava-register-webhook.mjs)
STRAVA_VERIFY_TOKEN=
# Public HTTPS URL Strava will call, e.g.
# https://fit-club-api-tsihm.ondigitalocean.app/api/app/strava/webhook
STRAVA_WEBHOOK_CALLBACK_URL=
# Optional scopes override (default: activity:read_all,profile:read_all)
# STRAVA_SCOPES=activity:read_all,profile:read_all
