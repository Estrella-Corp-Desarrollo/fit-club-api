{
  "kind": "collectionType",
  "collectionName": "running_profiles",
  "info": {
    "singularName": "running-profile",
    "pluralName": "running-profiles",
    "displayName": "Perfil de carrera",
    "description": "Ficha de carrera del atleta: fase, ritmos de referencia y meta de evento. Independiente de workout/workout-session."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "running_profile"
    },
    "phase": {
      "type": "enumeration",
      "enum": ["temporada", "pretemporada", "tapering"],
      "default": "temporada"
    },
    "thresholdPace": {
      "type": "string"
    },
    "easyPace": {
      "type": "string"
    },
    "intervalPace": {
      "type": "string"
    },
    "seriesPace": {
      "type": "string"
    },
    "group": {
      "type": "string"
    },
    "trackDays": {
      "type": "integer",
      "min": 0,
      "max": 7
    },
    "trackMode": {
      "type": "string"
    },
    "event": {
      "type": "string"
    },
    "eventDate": {
      "type": "date"
    },
    "goal": {
      "type": "text"
    },
    "notes": {
      "type": "text"
    }
  }
}
